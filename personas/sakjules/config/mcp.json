{
  "_comment": "SakJules — GitHub Repository Steward. Mirrors the Hermes profile MCP source of truth.",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_TOKEN}"
      }
    },
    "composio": {
      "command": "npx",
      "args": ["-y", "@composio/mcp@latest"],
      "env": {
        "COMPOSIO_API_KEY": "${COMPOSIO_API_KEY}"
      }
    }
  }
}
