# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtualenvs
.venv/
venv/
env/

# Node / dashboard build deps (the dashboard has its own .gitignore too)
node_modules/
# Stale duplicate of dashboard/ — kept only locally, never committed
web-dashboard/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.json
htmlcov/

# Local config / secrets
.env
.env.local

# Editor
.idea/
.vscode/
*.swp
.hermes/

# Persona skill runtime caches/state (regenerated; not authored content)
personas/*/skills/.hub/
personas/*/skills/.curator_state
personas/*/skills/.usage.json
personas/*/skills/.bundled_manifest

# Local scratch / build artifacts (never commit these)
/gitleaks
*.patch
changes.txt

# mutmut mutation-testing working copy + caches (regenerated by `mutmut run`)
/mutants/
.mutmut-cache
mutmut-cache

# Local-only Antigravity IDE scratch (untracked; never commit)
oh-my-antigravity/

# Hypothesis test database (local cache, must not be committed)
.hypothesis/
