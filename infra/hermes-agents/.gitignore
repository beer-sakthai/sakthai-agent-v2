# ── NEVER commit secrets or runtime data ──────────────────────────────
# Real env files (only .env.example templates belong here)
.env
*.env
.env.save
!*.env.example
!.env.example

# Auth / OAuth tokens
auth.json
*auth*.json
*.toml
.modal.toml
oauth_creds.json
google_oauth.json

# Databases / sessions / memory / caches (conversation data, PII)
*.db
*.db-shm
*.db-wal
sessions/
memories/
audio_cache/
image_cache/
cache/
logs/
*.log
*.pid
*.lock
